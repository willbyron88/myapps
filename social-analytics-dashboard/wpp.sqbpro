-- FIX 1: WPP-01 Episode 1 — wrong descriptions
-- This is the 2-min Sleep video, YouTube only. Not a full overview.
UPDATE content
SET content_pillar = 'Short-Form Overview',
    script_topic   = 'NotebookLM 2-Minute Video — Sleep &amp; Recovery Protocol'
WHERE content_id = 48;
 
 
-- FIX 2: WPP-04 Episode 1 — campaign still has placeholder text
UPDATE content
SET campaign = 'The Athena Protocol Launch'
WHERE content_id = 50;
 
 
-- FIX 3: WPP-03 Episode 1 — posted = N but URLs are filled in
-- Mark it posted if you've already published it today
UPDATE content
SET posted    = 'Y',
    post_date = date('now')
WHERE content_id = 51;
 
 
