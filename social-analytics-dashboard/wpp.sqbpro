UPDATE content
SET posted        = 'Y',
    instagram_url = 'https://www.instagram.com/reel/DYz7rDfp8hG/',
    youtube_url   = 'https://www.youtube.com/shorts/57MerdsCFtU',
    facebook_url  = 'https://www.facebook.com/reel/1255188883360661',
    x_url         = 'https://x.com/wpprotocols/status/2059337511697072259',
    post_date     = date('now')
WHERE book_key     = 'WPP-04'
AND   content_type = 'Short'
AND   short_num    = 1;  ← CHANGE THIS NUMBER

SELECT short_num, content_pillar, posted, post_date,
       instagram_url, youtube_url, facebook_url, x_url
FROM content WHERE book_key='WPP-04'
AND content_type='Short' ORDER BY short_num;



