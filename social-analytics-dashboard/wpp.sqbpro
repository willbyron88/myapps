-- Config Table — Comprehensive Strategic Data for CEO Dashboard
-- Sources: CEO Strategy V7 · 60 Book Titles · AI Research May 2026
-- Run in DB Browser → Write Changes
-- ═══════════════════════════════════════════════════════════════

CREATE TABLE IF NOT EXISTS config (
    key         TEXT PRIMARY KEY,
    value       TEXT,
    notes       TEXT,
    updated_at  TEXT DEFAULT (datetime('now'))
);


